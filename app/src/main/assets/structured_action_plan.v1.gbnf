char ::= [^"\\\x7F\x00-\x1F] | [\\] (["\\bfnrt] | "u" [0-9a-fA-F]{4})
clarification-needed ::= string | null
clarification-needed-kv ::= "\"clarification_needed\"" space ":" space clarification-needed
confidence-kv ::= "\"confidence\"" space ":" space number
decimal-part ::= [0-9]{1,16}
goal ::= ("\"CREATE_ALARM\"" | "\"CREATE_REMINDER\"" | "\"CREATE_CALENDAR_EVENT\"" | "\"SEND_MESSAGE\"" | "\"QUERY_INFO\"" | "\"NO_ACTION\"")
goal-kv ::= "\"goal\"" space ":" space goal
integral-part ::= [0] | [1-9] [0-9]{0,15}
null ::= "null"
number ::= ("-"? integral-part) ("." decimal-part)? ([eE] [-+]? integral-part)?
retrieved-context-used ::= "[" space (retrieved-context-used-item ("," space retrieved-context-used-item)*)? space "]"
retrieved-context-used-item ::= "{" space retrieved-context-used-item-source-kv "," space retrieved-context-used-item-record-id-kv space "}"
retrieved-context-used-item-record-id-kv ::= "\"record_id\"" space ":" space string
retrieved-context-used-item-source ::= ("\"sql\"" | "\"vector\"")
retrieved-context-used-item-source-kv ::= "\"source\"" space ":" space retrieved-context-used-item-source
retrieved-context-used-kv ::= "\"retrieved_context_used\"" space ":" space retrieved-context-used
retrieved-context-used-rest ::= ( "," space clarification-needed-kv )?
root ::= "{" space schema-version-kv "," space goal-kv "," space confidence-kv "," space slots-kv ( "," space ( retrieved-context-used-kv retrieved-context-used-rest | clarification-needed-kv ) )? space "}"
schema-version ::= "\"1\""
schema-version-kv ::= "\"schema_version\"" space ":" space schema-version
slots ::= "{" space  (slots-person-reference-kv slots-person-reference-rest | slots-event-reference-kv slots-event-reference-rest | slots-topic-reference-kv slots-topic-reference-rest | slots-temporal-expression-kv slots-temporal-expression-rest | slots-numeric-constraints-kv slots-numeric-constraints-rest | slots-message-body-kv )? space "}"
slots-event-reference ::= slots-event-reference-0 | null
slots-event-reference-0 ::= "{" space slots-event-reference-0-raw-text-kv ( "," space ( slots-event-reference-0-fuzzy-time-hint-kv ) )? space "}"
slots-event-reference-0-fuzzy-time-hint ::= string | null
slots-event-reference-0-fuzzy-time-hint-kv ::= "\"fuzzy_time_hint\"" space ":" space slots-event-reference-0-fuzzy-time-hint
slots-event-reference-0-raw-text-kv ::= "\"raw_text\"" space ":" space string
slots-event-reference-kv ::= "\"event_reference\"" space ":" space slots-event-reference
slots-event-reference-rest ::= ( "," space slots-topic-reference-kv )? slots-topic-reference-rest
slots-kv ::= "\"slots\"" space ":" space slots
slots-message-body ::= string | null
slots-message-body-kv ::= "\"message_body\"" space ":" space slots-message-body
slots-numeric-constraints ::= "[" space (slots-numeric-constraints-item ("," space slots-numeric-constraints-item)*)? space "]"
slots-numeric-constraints-item ::= "{" space slots-numeric-constraints-item-kind-kv "," space slots-numeric-constraints-item-value-kv "," space slots-numeric-constraints-item-unit-kv space "}"
slots-numeric-constraints-item-kind ::= ("\"offset_before\"" | "\"offset_after\"" | "\"duration\"" | "\"buffer\"")
slots-numeric-constraints-item-kind-kv ::= "\"kind\"" space ":" space slots-numeric-constraints-item-kind
slots-numeric-constraints-item-unit ::= ("\"minutes\"" | "\"hours\"" | "\"days\"")
slots-numeric-constraints-item-unit-kv ::= "\"unit\"" space ":" space slots-numeric-constraints-item-unit
slots-numeric-constraints-item-value-kv ::= "\"value\"" space ":" space number
slots-numeric-constraints-kv ::= "\"numeric_constraints\"" space ":" space slots-numeric-constraints
slots-numeric-constraints-rest ::= ( "," space slots-message-body-kv )?
slots-person-reference ::= slots-person-reference-0 | null
slots-person-reference-0 ::= "{" space slots-person-reference-0-raw-text-kv space "}"
slots-person-reference-0-raw-text-kv ::= "\"raw_text\"" space ":" space string
slots-person-reference-kv ::= "\"person_reference\"" space ":" space slots-person-reference
slots-person-reference-rest ::= ( "," space slots-event-reference-kv )? slots-event-reference-rest
slots-temporal-expression ::= slots-temporal-expression-0 | null
slots-temporal-expression-0 ::= "{" space slots-temporal-expression-0-raw-text-kv space "}"
slots-temporal-expression-0-raw-text-kv ::= "\"raw_text\"" space ":" space string
slots-temporal-expression-kv ::= "\"temporal_expression\"" space ":" space slots-temporal-expression
slots-temporal-expression-rest ::= ( "," space slots-numeric-constraints-kv )? slots-numeric-constraints-rest
slots-topic-reference ::= slots-topic-reference-0 | null
slots-topic-reference-0 ::= "{" space slots-topic-reference-0-raw-text-kv space "}"
slots-topic-reference-0-raw-text-kv ::= "\"raw_text\"" space ":" space string
slots-topic-reference-kv ::= "\"topic_reference\"" space ":" space slots-topic-reference
slots-topic-reference-rest ::= ( "," space slots-temporal-expression-kv )? slots-temporal-expression-rest
space ::= | " " | "\n"{1,2} [ \t]{0,20}
string ::= "\"" char* "\""
